# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# API Configuration
# Backend API URL - change this to your Railway backend URL in production
REACT_APP_API_URL=http://localhost:8000

# For production deployment
# REACT_APP_API_URL=https://your-app.railway.app

# App Configuration
REACT_APP_NAME=LearnOnTheGo
REACT_APP_VERSION=0.1.0

# Storage Configuration
# Maximum number of lectures to store locally (free tier)
REACT_APP_MAX_LOCAL_LECTURES=10

# Audio Configuration
REACT_APP_DEFAULT_PLAYBACK_SPEED=1.0
REACT_APP_SUPPORTED_SPEEDS=0.5,0.75,1.0,1.25,1.5,2.0

# File Upload Configuration
REACT_APP_MAX_PDF_SIZE_MB=50
REACT_APP_ALLOWED_PDF_TYPES=application/pdf

# Feature Flags
REACT_APP_ENABLE_PDF_UPLOAD=true
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_SOCIAL_LOGIN=false

# Development Configuration
REACT_APP_DEBUG=false
REACT_APP_LOG_LEVEL=warn

# Analytics (optional)
# REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# REACT_APP_MIXPANEL_TOKEN=your_mixpanel_token

# Error Tracking (optional)
# REACT_APP_SENTRY_DSN=your_sentry_dsn

# Social Login (Phase 2)
# REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
# REACT_APP_APPLE_CLIENT_ID=your_apple_client_id

# PWA Configuration
REACT_APP_THEME_COLOR=#000000
REACT_APP_BACKGROUND_COLOR=#ffffff
GENERATE_SOURCEMAP=false

# Performance Configuration
REACT_APP_AUDIO_PRELOAD=metadata
REACT_APP_LAZY_LOAD_IMAGES=true

# Accessibility Configuration
REACT_APP_MIN_FONT_SIZE=16
REACT_APP_HIGH_CONTRAST_MODE=false
REACT_APP_REDUCED_MOTION=false
