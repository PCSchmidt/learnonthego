# Development Environment Configuration for Cost-Free Testing
# Copy this to .env for local development

# 🎭 MOCK MODE - Enable for cost-free testing (no API calls)
MOCK_MODE=true

# 🔑 Real API Keys (only use for minimal production testing)
# OPENROUTER_API_KEY=your-openrouter-key-here
# ELEVENLABS_API_KEY=your-elevenlabs-key-here

# 🔐 Security Settings
JWT_SECRET_KEY=your-jwt-secret-key-for-development
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# 🗄️ Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/learnonthego

# 🌐 Application Settings
DEBUG=true
ENVIRONMENT=development

# 💰 Cost Control Settings
MAX_LECTURES_PER_HOUR=10
MAX_LECTURE_DURATION_MINUTES=60
MAX_PDF_SIZE_MB=50

# 📊 Logging
LOG_LEVEL=INFO
LOG_API_USAGE=true

# ⚠️ IMPORTANT COST REMINDERS:
# - MOCK_MODE=true prevents all external API calls
# - Only disable MOCK_MODE for final testing with real APIs
# - Each real lecture costs approximately $0.50-2.00
# - Always monitor API usage and costs
# - Users should provide their own API keys in production
