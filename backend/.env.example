# Backend Environment Variables - Phase 1 AI Integration
# Copy this file to .env and fill in your actual values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database Configuration

# For Docker Compose (local development)
DATABASE_URL=postgresql://postgres:postgres@db:5432/learnonthego

# For production (PostgreSQL on Railway - automatically provided)
# DATABASE_URL=postgresql://username:password@host:port/database

# Security & Encryption
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
ENCRYPTION_MASTER_KEY=your-master-encryption-key-for-api-keys-32-chars-min

# AI Service Integration (Phase 1)
# Users provide their own API keys through the app
# These are optional fallback keys for testing
OPENROUTER_API_KEY=your-openrouter-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# V2 feature-flagged provider-agnostic pipeline (document -> script -> audio)
ENABLE_V2_PIPELINE=false
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Cloudinary Configuration (for file storage)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate Limiting Configuration
RATE_LIMIT_LECTURES_PER_HOUR=10
RATE_LIMIT_PDF_UPLOADS_PER_HOUR=5
RATE_LIMIT_LOGIN_ATTEMPTS=5

# File Storage & Processing (Phase 1)
UPLOAD_DIR=temp_uploads
AUDIO_DIR=temp_audio
MAX_FILE_SIZE=52428800  # 50MB in bytes
MAX_PDF_SIZE_MB=50
MAX_LECTURE_DURATION_MINUTES=60
MIN_LECTURE_DURATION_MINUTES=5
MAX_PDF_PAGES=200
MAX_TOPIC_LENGTH=500
MAX_CONTEXT_LENGTH=2000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,https://*.vercel.app
ENABLE_CORS=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# AI Service Configuration (Phase 1)
AI_SERVICES_ENABLED=true
PDF_PROCESSING_ENABLED=true
TTS_ENABLED=true
ENCRYPTION_ENABLED=true
LLM_TIMEOUT=120
TTS_TIMEOUT=60
PDF_PROCESSING_TIMEOUT=30

# File Cleanup Configuration
AUTO_DELETE_FILES_HOURS=24
CLEANUP_SCHEDULE_HOURS=6

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Development Configuration
DEBUG=true
TESTING=false

# Phase 1 Development Status
PHASE=1
FEATURES_READY=openrouter,pdf_processing,tts,encryption
NEXT_PHASE=database_integration,frontend_connection
# ANALYTICS_API_KEY=your_analytics_key

# AI Services Configuration
# OpenRouter for LLM services (get from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs for TTS services (get from https://elevenlabs.io/)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Development vs Production
ENVIRONMENT=development
