# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For local development (SQLite)
DATABASE_URL=sqlite:///./learnonthego.db

# For production (PostgreSQL on Railway - automatically provided)
# DATABASE_URL=postgresql://username:password@host:port/database

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Cloudinary Configuration (for file storage)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate Limiting Configuration
RATE_LIMIT_LECTURES_PER_HOUR=10
RATE_LIMIT_PDF_UPLOADS_PER_HOUR=5
RATE_LIMIT_LOGIN_ATTEMPTS=5

# API Configuration
# Optional: Fallback API keys for system use (not recommended for production)
# OPENROUTER_FALLBACK_KEY=your_openrouter_key
# ELEVENLABS_FALLBACK_KEY=your_elevenlabs_key

# CORS Configuration
# Add your frontend URLs here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://yourdomain.vercel.app

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance Configuration
MAX_PDF_SIZE_MB=50
MAX_LECTURE_DURATION_MINUTES=60
LECTURE_CACHE_TTL_HOURS=24

# Development Configuration
DEBUG=False
TESTING=False

# External API Timeouts (seconds)
LLM_TIMEOUT=120
TTS_TIMEOUT=60
PDF_PROCESSING_TIMEOUT=30

# File Cleanup Configuration
AUTO_DELETE_FILES_HOURS=24
CLEANUP_SCHEDULE_HOURS=6

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Monitoring (optional)
# SENTRY_DSN=your_sentry_dsn
# ANALYTICS_API_KEY=your_analytics_key
